# ======================================================
# VARIABLES DE ENTORNO - BACKEND SPRING BOOT
# ======================================================
# Este archivo documenta las variables de entorno disponibles.
# Copia este archivo a .env y ajusta los valores según tu entorno.

# ======================================================
# BASE DE DATOS
# ======================================================
# XAMPP usa valores por defecto (no necesitas .env)
# Docker sobrescribe estos valores en docker-compose.yml

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/gestion_ingenieria?useSSL=false&serverTimezone=Europe/Madrid
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect

# ======================================================
# HIBERNATE
# ======================================================
# validate: verifica schema (producción)
# update: actualiza schema automáticamente (desarrollo)
# create-drop: recrea schema cada vez (testing)

SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=true

# ======================================================
# JWT
# ======================================================
JWT_SECRET=9a4f2c8d3b7e1f0g2h5j8k9l0m1n4o7p2q5r8s1t4u7v0w3x6y9z
JWT_EXPIRATION_MS=86400000

# ======================================================
# SERVIDOR
# ======================================================
SERVER_PORT=8082

# ======================================================
# ARCHIVOS
# ======================================================
FILE_UPLOAD_DIR=uploads

# ======================================================
# SEEDERS
# ======================================================
SEED_ADMIN=true
SEED_DEMO=false
