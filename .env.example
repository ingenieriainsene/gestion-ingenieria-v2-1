# ======================================================
# CONFIGURACIÓN DEL PROYECTO (DOCKER COMPOSE)
# ======================================================
# Copia este archivo a .env para personalizar tu entorno.
# NO subas el archivo .env al repositorio (gitignored).

# --- Base de Datos (PostgreSQL/Supabase) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gestion_ingenieria
# PUERTO EXTERNO: Cambia esto si el puerto está ocupado en tu máquina
# Ej: En casa usa 54322, en la oficina usa 5432
DB_PORT_HOST=54322

# --- Backend (Spring Boot) ---
# Puerto donde el backend escuchará en localhost
BACKEND_PORT=8082

# --- Frontend (Angular) ---
# Puerto donde el frontend escuchará en localhost (Docker Profile Full)
FRONTEND_PORT=80

# --- JWT (Seguridad) ---
JWT_SECRET=9a4f2c8d3b7e1f0g2h5j8k9l0m1n4o7p2q5r8s1t4u7v0w3x6y9z
JWT_EXPIRATION_MS=86400000

# --- Opciones Extra ---
# true = crear datos de prueba al iniciar
SEED_DEMO=false
